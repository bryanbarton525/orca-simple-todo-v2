{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "exclude": [
    "node_modules",
    "lib/**",
    "app/lib/**",
    "app/lib/supabase-client.ts"
  ],
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "prisma/**/*.ts",
    "next-env.d.ts"
  ]
}