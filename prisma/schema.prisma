generator client {
  provider = "prisma-client-js"
}

 datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model UserSettings {
  id        Int      @id @default(autoincrement())
  feedUrls  String[]
  darkMode  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id          Int      @id @default(autoincrement())
  feedUrl     String
  title       String
  description String?
  content     String?
  publishedAt DateTime
  readAt      DateTime?
  tags        String[]
  userId      Int?
  user        UserSettings? @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([feedUrl])
  @@index([publishedAt])
}
