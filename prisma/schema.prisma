datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model NewsItem {
  id          Int      @id @default(autoincrement())
  title       String
  link        String
  pubDate     DateTime
  description String
  source      String
  createdAt   DateTime @default(now())
}